{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "eqeqeq": "warn",
    "no-var": "warn",
    "prefer-const": "warn",
    "no-empty": "warn",
    "no-unreachable": "error",
    "no-constant-condition": "warn",
    "no-debugger": "error",
    "no-duplicate-case": "error",
    "no-extra-semi": "warn",
    "no-func-assign": "error",
    "no-undef": "warn",
    "semi": ["warn", "always"],
    "curly": "warn"
  }
}
